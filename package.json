{
  "name": "local-websites",
  "version": "1.0.0",
  "description": "Waypoint Local — automated website prospecting and build pipeline",
  "type": "module",
  "scripts": {
    "setup":   "node --import=./tools/_load-env.js tools/check-status.js --setup",
    "status":  "node --import=./tools/_load-env.js tools/check-status.js",

    "discover":              "node --import=./tools/_load-env.js tools/discover-leads.js --all --radius 50000",
    "discover:restaurant":   "node --import=./tools/_load-env.js tools/discover-leads.js --category restaurant --radius 50000",
    "discover:lodging":      "node --import=./tools/_load-env.js tools/discover-leads.js --category lodging --radius 50000",
    "discover:professional": "node --import=./tools/_load-env.js tools/discover-leads.js --category professional-services --radius 50000",
    "discover:retail":       "node --import=./tools/_load-env.js tools/discover-leads.js --category retail-boutique --radius 50000",
    "discover:auto":         "node --import=./tools/_load-env.js tools/discover-leads.js --category auto-services --radius 50000",
    "discover:outdoor":      "node --import=./tools/_load-env.js tools/discover-leads.js --category outdoor-adventure --radius 50000",

    "audit":     "node --import=./tools/_load-env.js tools/audit-urls.js --all",
    "audit:url": "node --import=./tools/_load-env.js tools/audit-urls.js --url",

    "score": "node --import=./tools/_load-env.js tools/score-leads.js --all",
    "queue": "node --import=./tools/_load-env.js tools/score-leads.js --queue",

    "export": "node --import=./tools/_load-env.js tools/export-leads.js",

    "sweep": "npm run discover && npm run audit && npm run score && npm run export",

    "digital-audit": "node --import=./tools/_load-env.js tools/digital-audit.js",
    "scrape":        "node --import=./tools/_load-env.js tools/scrape-existing-site.js",
    "reviews":       "node --import=./tools/_load-env.js tools/scrape-reviews.js",
    "voice":         "node --import=./tools/_load-env.js tools/generate-voice-brief.js",
    "copy":          "node --import=./tools/_load-env.js tools/generate-copy.js",
    "apply":         "node --import=./tools/_load-env.js tools/apply-copy.js",
    "deploy":        "node --import=./tools/_load-env.js tools/deploy-demo.js",
    "package":       "node --import=./tools/_load-env.js tools/package-site.js",
    "pipeline":      "node --import=./tools/_load-env.js tools/run-pipeline.js",

    "email:send": "node --import=./tools/_load-env.js tools/send-email.js",
    "crm:update": "node --import=./tools/_load-env.js tools/update-crm.js",

    "push": "bash push.sh"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.52.0",
    "dotenv": "^16.0.0",
    "googleapis": "^144.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
