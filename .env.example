# =============================================================================
# LOCAL WEBSITES — Environment Variables
# Copy this file to .env in each template or tool directory that needs it.
# NEVER commit .env files to git — they are in .gitignore.
# =============================================================================

# -----------------------------------------------------------------------
# AI / COPY GENERATION
# -----------------------------------------------------------------------

# Anthropic Claude API — used by generate-copy.js and generate-voice-brief.js
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenAI — optional fallback for generate-copy.js
# Get your key at: https://platform.openai.com/
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# -----------------------------------------------------------------------
# GOOGLE APIs
# -----------------------------------------------------------------------

# Google Places API — used by scrape-reviews.js
# Enable "Places API" at: https://console.cloud.google.com/
# Billing must be enabled. First $200/month is free (well above our usage).
GOOGLE_PLACES_API_KEY=AIzaXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Google PageSpeed Insights API — used by audit-urls.js
# Enable "PageSpeed Insights API" in the same console.
# Same key can be reused if both APIs are enabled on the project.
GOOGLE_PAGESPEED_API_KEY=AIzaXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX


# -----------------------------------------------------------------------
# DEPLOYMENT
# -----------------------------------------------------------------------

# Vercel Personal Access Token — used by deploy-demo.js
# Generate at: https://vercel.com/account/tokens
VERCEL_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Vercel Team ID (optional — only needed if deploying to a Vercel team)
# VERCEL_TEAM_ID=team_xxxxxxxxxxxxxxxxxxxxxxxx


# -----------------------------------------------------------------------
# EMAIL / OUTREACH
# -----------------------------------------------------------------------

# Resend API Key — used for sending outreach emails
# Sign up at: https://resend.com (free tier: 100 emails/day)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# The "From" address for outreach emails (must be a verified Resend domain)
EMAIL_FROM=kelsey@yourdomain.com

# Reply-to address for outreach emails
EMAIL_REPLY_TO=kelsey@yourdomain.com


# -----------------------------------------------------------------------
# CONTENT SCRAPING
# -----------------------------------------------------------------------

# Jina.ai API Key — used by scrape-existing-site.js (optional, free tier works without key)
# Sign up at: https://jina.ai for higher rate limits
JINA_API_KEY=jina_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# BuiltWith API Key — used by audit-urls.js for tech stack detection
# Sign up at: https://builtwith.com/api (free tier available)
BUILTWITH_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# -----------------------------------------------------------------------
# NOTIFICATIONS
# -----------------------------------------------------------------------

# Telegram Bot Token — used by N8N to notify you of warm replies
# Create a bot via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=xxxxxxxxxx:xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Your Telegram User ID (get from @userinfobot on Telegram)
TELEGRAM_CHAT_ID=123456789

# Slack Webhook URL — alternative notification channel
# Create at: https://api.slack.com/apps → Incoming Webhooks
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz


# -----------------------------------------------------------------------
# CRM / AUTOMATION
# -----------------------------------------------------------------------

# Google Sheets ID for the prospect CRM
# Found in the Sheet URL: docs.google.com/spreadsheets/d/[THIS_ID]/edit
GOOGLE_SHEET_ID=1xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# N8N Webhook URL — trigger discovery loop manually
# N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/xxxx
